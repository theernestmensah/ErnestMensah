# Use a Paystack test secret while developing and a live secret only in production.
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here

# Required in production so Paystack redirects to the public site after checkout.
PUBLIC_URL=https://your-domain.com

# Optional server configuration.
PORT=5175
HOST=127.0.0.1
